{
  "appId": "com.keybuddy.school",
  "productName": "Key Buddy School",
  "copyright": "Copyright © 2026 The Jump Vault",
  "icon": "build/icon.ico",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-school/**/*",
    "electron/**/*",
    "build/icon.ico",
    "build/icon.png",
    "package.json"
  ],
  "asar": true,
  "extraMetadata": {
    "edition": "school"
  },
  "afterPack": "./scripts/after-pack-sign.cjs",
  "afterAllArtifactBuild": "./scripts/checksums.cjs",
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "signtoolOptions": {
      "sign": "./scripts/sign-win.cjs",
      "publisherName": "The Jump Vault"
    },
    "signAndEditExecutable": false,
    "artifactName": "Keyboard-Learning-School-${version}-setup.exe"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "artifactName": "Keyboard-Learning-School-${version}-setup.exe"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "enachealex",
      "repo": "Keyboard-Learning"
    }
  ]
}
